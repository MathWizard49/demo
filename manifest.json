{
  "manifest_version": 3,
  "name": "Reading Time",
  "version": "1.0",
  "description": "Shows word count and reading time for any webpage",

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "permissions": ["tabs"]
}
